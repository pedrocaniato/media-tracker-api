generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

// ----------------------------------------------------
// SEUS MODELOS DE DADOS (USER, MEDIA, USERMEDIA)
// ----------------------------------------------------

model User {
  id        String      @id @default(cuid())
  username  String?     @unique
  email     String      @unique
  password  String
  name      String?
  bio       String?
  image     String?
  createdAt DateTime    @default(now())

  media     UserMedia[]
}

model UserMedia {
  id          String   @id @default(cuid())

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  // 🔑 identidade da mídia (vem da API externa)
  uniqueId    String   // TMDB:movie:550 | GB:abc
  type        String   // filme | serie | livro
  title       String
  posterUrl   String?
  releaseYear Int?

  // 📌 status do usuário
  status      MediaStatus

  // ⭐ avaliação
  rating      Float?
  review      String?
  isFavorite  Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 🚨 regra de ouro
  @@unique([userId, uniqueId])
}

enum MediaStatus {
  VISTO
  ASSISTINDO
  QUERO_VER
}
